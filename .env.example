# Core runtime
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/cognicare

# Security
JWT_SECRET=replace-with-a-long-random-secret
CHATBOT_CONFIRM_SECRET=replace-with-a-separate-long-random-secret
MESSAGES_ENCRYPTION_KEY=replace-with-a-long-random-32-byte-key
SWAGGER_ENABLED=false

# Origins
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
BACKEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173
FRONTEND_URL=http://localhost:8080

# Optional AI providers
OPENAI_API_KEY=
GROQ_API_KEY=
CHATBOT_SIMPLE_GROQ_MODEL=llama-3.1-8b-instant
CHATBOT_COMPLEX_GROQ_MODEL=llama-3.3-70b-versatile
CHATBOT_SIMPLE_OPENAI_MODEL=gpt-4o-mini
CHATBOT_COMPLEX_OPENAI_MODEL=gpt-4o-mini

# Mail / uploads / payments
SENDGRID_API_KEY=
MAIL_FROM=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optional integrations
DEEPGRAM_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
CAREGIVER_CERTIFICATE_TEMPLATE_PATH=

# DevSecOps / observability
METRICS_ENABLED=false
SENTRY_DSN=
METRICS_ENABLED=false
RENDER_DEPLOY_HOOK=
